5" y="-105" w="150" h="90" /></stage><stage stageid="e829994e-858c-425f-ba43-389d3ee500d4" name="Launch Applications" type="SubSheetInfo"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><display x="-195" y="-105" w="150" h="90" /></stage><stage stageid="a977521a-3999-4009-8495-a9c837315f7a" name="Start" type="Start"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><display x="15" y="-105" /><onsuccess>f0a2f002-5d65-47e8-b23e-72422020f3ee</onsuccess></stage><stage stageid="b1bd9a23-dc9c-47e4-b8ea-915fa9d965a3" name="End" type="End"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><display x="15" y="120" /></stage><stage stageid="f0a2f002-5d65-47e8-b23e-72422020f3ee" name="Launch ACME System" type="Action"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><loginhibit onsuccess="true" /><display x="15" y="-30" w="90" h="30" /><onsuccess>2bbb21c6-78e2-418d-88c6-b59ad13defd7</onsuccess><resource object="Calculate Client Security Hash - ACME System Object" action="Launch or Attach" /></stage><stage stageid="6d61da4a-dcb8-475f-8053-4d764c642403" name="Launch Applications" type="SubSheet"><loginhibit onsuccess="true" /><display x="15" y="-105" w="90" h="60" /><onsuccess>e4a2fb41-22f2-4156-9757-2a3492bf3e74</onsuccess><processid>2a4db835-8273-4685-ad70-bca1f1494c47</processid></stage><stage stageid="2bbb21c6-78e2-418d-88c6-b59ad13defd7" name="Launch_Sha-1" type="Action"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><loginhibit onsuccess="true" /><display x="15" y="45" w="90" h="30" /><onsuccess>b1bd9a23-dc9c-47e4-b8ea-915fa9d965a3</onsuccess><resource object="Calculate Client Security Hash - Sha-1 Object" action="Launch or Attach" /></stage><stage stageid="d1e88889-df22-4728-91b4-4d5212c9cfeb" name="Close Applications" type="SubSheetInfo"><subsheetid>a873fbb9-bff4-49ac-ba9f-dfa8a532e9b9</subsheetid><display x="-195" y="-105" w="150" h="90" /></stage><stage stageid="6a53993a-f01e-4a59-84c3-1763532a4067" name="Start" type="Start"><subsheetid>a873fbb9-bff4-49ac-ba9f-dfa8a532e9b9</subsheetid><display x="15" y="-105" /><onsuccess>418ab98c-e9b6-41fd-bb09-96738dc15d2d</onsuccess></stage><stage stageid="49d50d65-aeb1-4c6f-a6c1-39b22ee17c4e" name="End" type="End"><subsheetid>a873fbb9-bff4-49ac-ba9f-dfa8a532e9b9</subsheetid><display x="15" y="90" /></stage><stage stageid="418ab98c-e9b6-41fd-bb09-96738dc15d2d" name="Close Application" type="Action"><subsheetid>a873fbb9-bff4-49ac-ba9f-dfa8a532e9b9</subsheetid><loginhibit onsuccess="true" /><display x="15" y="-15" w="90" h="30" /><onsuccess>49d50d65-aeb1-4c6f-a6c1-39b22ee17c4e</onsuccess><resource object="Calculate Client Security Hash - Sha-1 Object" action="Close" /></stage><stage stageid="2d1147f4-eb2a-4c2e-91d8-b6fc59b02487" name="Close Applications" type="SubSheet"><loginhibit onsuccess="true" /><display x="15" y="75" w="90" h="60" /><onsuccess>98e26f36-7bde-4071-9f1a-e38ed9d176f5</onsuccess><processid>a873fbb9-bff4-49ac-ba9f-dfa8a532e9b9</processid></stage><stage stageid="e4a2fb41-22f2-4156-9757-2a3492bf3e74" name="Processing the queue" type="SubSheet"><loginhibit onsuccess="true" /><display x="15" y="-15" w="90" h="60" /><onsuccess>2d1147f4-eb2a-4c2e-91d8-b6fc59b02487</onsuccess><processid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</processid></stage><stage stageid="b8dbe86a-8b8e-4dda-b344-014814a95888" name="Exception Detail" type="Data"><display x="-165" y="60" w="120" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="4d31f738-4395-4312-aae8-938630d1e51d" name="Exception Type" type="Data"><display x="-165" y="15" w="120" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="75362133-f684-4ff9-8f21-58fca491fdb2" name="Exception Stage" type="Data"><display x="-165" y="105" w="120" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="90c97e8f-e597-4130-999d-bac25c27e084" name="Global Recover" type="Recover"><loginhibit /><display x="345" y="-195" /><onsuccess>90a8c4b0-b9b6-4fa4-ba0f-8b1621a766ea</onsuccess></stage><stage stageid="ad580513-768a-4d33-b5fb-35d4597e7148" name="Resume" type="Resume"><loginhibit /><display x="345" y="45" /><onsuccess>7081f389-f813-440a-87d0-47aee45339c6</onsuccess></stage><stage stageid="90a8c4b0-b9b6-4fa4-ba0f-8b1621a766ea" name="Exception Detail" type="MultipleCalculation"><loginhibit onsuccess="true" /><display x="345" y="-120" w="90" h="60" /><onsuccess>0d521a4e-1d2a-4c8c-8872-e6cbd0e49778</onsuccess><steps><calculation expression="ExceptionType()" stage="Exception Type" /><calculation expression="ExceptionDetail()" stage="Exception Detail" /><calculation expression="&quot;There is a problem with stage &quot;&amp;ExceptionStage()" stage="Exception Stage" /></steps></stage><stage stageid="7081f389-f813-440a-87d0-47aee45339c6" name="Close Application" type="SubSheet"><loginhibit onsuccess="true" /><display x="345" y="135" w="90" h="60" /><onsuccess>50cf7344-b2b0-4b99-b7b1-50f8f4e12dc4</onsuccess><processid>a873fbb9-bff4-49ac-ba9f-dfa8a532e9b9</processid></stage><stage stageid="50cf7344-b2b0-4b99-b7b1-50f8f4e12dc4" name="Sending Mail" type="Process"><loginhibit onsuccess="true" /><display x="240" y="135" w="90" h="30" /><inputs><input type="text" name="Messsage" friendlyname="Messsage" narrative="Emailing" expr="[Exception Detail]" /><input type="text" name="Attachment" friendlyname="Attachment" narrative="Email Attachment" expr="[SS details.Attachment]" /><input type="text" name="Subject" friendlyname="Subject" narrative="Exeption Stage" expr="[Exception Stage]" /></inputs><onsuccess>737a6cd1-c403-4d92-b22a-7e0b1acd0750</onsuccess><processid>a866356a-ae72-4f8e-bd92-8643a99eb062</processid></stage><stage stageid="0d521a4e-1d2a-4c8c-8872-e6cbd0e49778" name="Get SS Path" type="SubSheet"><loginhibit onsuccess="true" /><display x="345" y="-30" w="90" h="60" /><onsuccess>ad580513-768a-4d33-b5fb-35d4597e7148</onsuccess><processid>339d4ec6-0abe-4468-8a65-0c5099e142b9</processid></stage><stage stageid="737a6cd1-c403-4d92-b22a-7e0b1acd0750" name="Mark Queue Item Complete" type="SubSheet"><loginhibit onsuccess="true" /><display x="120" y="135" w="90" h="60" /><onsuccess>98e26f36-7bde-4071-9f1a-e38ed9d176f5</onsuccess><processid>1d205568-8480-479a-940e-23f68579eaa7</processid></stage><stage stageid="707d675d-a6ae-43dd-bde0-40b41639a255" name="Get SS Path" type="SubSheetInfo"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><display x="-195" y="-105" w="150" h="90" /></stage><stage stageid="26c7fa53-ad2e-43e1-a5cb-2538d41c6065" name="Start" type="Start"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><display x="15" y="-105" /><onsuccess>c75fbde9-b098-454a-bb6b-d2358659e1ce</onsuccess></stage><stage stageid="2418a153-1186-4a91-bf57-896f7d95b2f4" name="End" type="End"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><display x="15" y="90" /></stage><stage stageid="c75fbde9-b098-454a-bb6b-d2358659e1ce" name="Get SS Detail" type="Action"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><narrative>This action gets the next item to be worked from the queue, returning its details and locking it so no other case can work it.

Items with higher priorities (lower numerical value) are processed first. Where the priority is the same, the next item is the one that has been in the queue the longest,  is not already locked, and is not already completed.

The Item ID returned is used to make further calls to update the work status for that item. It may be empty, in which case there are no items available. This can mean either a) the queue is empty, or b) the queue is not running. This mechanism can be used to cleanly stop all processes working a particular queue at the end of the next case. Items that have a 'deferred' time set will not be returned unless that time has been reached.</narrative><display x="15" y="-15" w="120" h="30" /><inputs><input type="text" name="Queue Name" friendlyname="Queue Name" narrative="The name of the queue" expr="&quot;Attachment Queue For Error SS&quot;" /><input type="text" name="Key Filter" friendlyname="Key Filter" narrative="Optionally, a key value to filter by. Only items with this key value will be considered." expr="" /><input type="text" name="Tag Filter" friendlyname="Tag Filter" narrative="Optionally, a tag mask to filter by. This can consist of any number of tag searches - each term can be separated by a semi-colon and they are all applied to the search (ie. they are AND'ed terms not OR'ed terms). For example, &quot;Account: Joint; -Balance: Overdrawn; Card: *Visa*&quot; will include any items which match all the terms, ie. every item must have an 'Account: Joint' tag applied, no item can have a 'Balance: Overdrawn' tag applied, every item must have a tag applied which starts with 'Card: ' and then contains the text 'Visa'." expr="" /><input type="text" name="Sort Order" friendlyname="Sort Order" narrative="Sort order method (Priority, SLA, PriorityAndSLA)" expr="" /></inputs><outputs><output type="text" name="Item ID" friendlyname="Item ID" narrative="The ID of the item retrieved - empty if there are none available." stage="Item ID SS Details" /><output type="collection" name="Data" friendlyname="Data" narrative="The data associated with the item - a single collection row." stage="SS details" /><output type="text" name="Status" friendlyname="Status" narrative="The status of the item." stage="" /><output type="number" name="Attempts" friendlyname="Attempts" narrative="The number of attempts already made to work this item." stage="" /></outputs><onsuccess>2418a153-1186-4a91-bf57-896f7d95b2f4</onsuccess><resource object="Blueprism.Automate.clsWorkQueuesActions" action="Get Next Item" /></stage><stage stageid="25980d3e-7dbb-4d5a-8093-4051f5d02805" name="SS details" type="Collection"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><display x="-180" y="0" w="150" h="30" /><datatype>collection</datatype><alwaysinit /></stage><stage stageid="fe5563ae-5a8e-4ad0-9375-1e6832ab7a8f" name="Mark Item Completed" type="SubSheetInfo"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><display x="-195" y="-105" w="150" h="90" /></stage><stage stageid="a205a919-9dee-4d47-ae00-d84877fc6f7a" name="Start" type="Start"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><display x="15" y="-120" /><onsuccess>4839c24f-d904-4930-afd8-9fd8ad574259</onsuccess></stage><stage stageid="4fb3e9dd-4521-44ec-b69b-44b1c22be78a" name="End" type="End"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><display x="-120" y="60" /></stage><stage stageid="72b56a2d-69fa-439c-b47d-6fb7eabeeba9" name="Mark Item completed" type="Action"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><loginhibit onsuccess="true" /><narrative>Marks the item as completed, by updating the Completed timestamp and setting Locked to null. The item must be 'owned' by the calling process - i.e. it must have been retrieved using Get Next Item.</narrative><display x="15" y="60" w="90" h="30" /><inputs><input type="text" name="Item ID" friendlyname="Item ID" narrative="The ID of the item to mark" expr="[Item ID SS Details]" /></inputs><onsuccess>4fb3e9dd-4521-44ec-b69b-44b1c22be78a</onsuccess><resource object="Blueprism.Automate.clsWorkQueuesActions" action="Mark Completed" /></stage><stage stageid="c1aaf684-8fd6-4917-9502-e5ae5c680350" name="Try Marking Complete" type="Recover"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><loginhibit /><display x="195" y="-105" w="90" h="30" /><onsuccess>d63901d2-57ff-4e01-86a0-7eaa75be6083</onsuccess><attempts>2</attempts><bubbleException>False</bubbleException></stage><stage stageid="d63901d2-57ff-4e01-86a0-7eaa75be6083" name="Resume" type="Resume"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><loginhibit /><display x="195" y="-30" w="90" h="30" /><onsuccess>4839c24f-d904-4930-afd8-9fd8ad574259</onsuccess></stage><stage stageid="4839c24f-d904-4930-afd8-9fd8ad574259" name="Item ID?" type="Decision"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><display x="15" y="-30" w="90" h="60" /><decision expression="[Item ID SS Details]&lt;&gt;&quot;&quot;" /><ontrue>72b56a2d-69fa-439c-b47d-6fb7eabeeba9</ontrue><onfalse>dd2a5a61-cc81-4677-8fa3-b6d33b8d3d87</onfalse></stage><stage stageid="dd2a5a61-cc81-4677-8fa3-b6d33b8d3d87" name="Anchor1" type="Anchor"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><loginhibit onsuccess="true" /><display x="-120" y="-30" w="10" h="10" /><onsuccess>4fb3e9dd-4521-44ec-b69b-44b1c22be78a</onsuccess></stage><stage stageid="66288959-43a9-44ed-8323-03017d97677e" name="Item ID SS Details" type="Data"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><display x="-180" y="45" w="150" h="30" /><datatype>text</datatype><initialvalue /><alwaysinit /></stage><stage stageid="28c312ff-7cd3-454a-9f5b-dffc4b92cee4" name="Note" type="Note"><subsheetid>a873fbb9-bff4-49ac-ba9f-dfa8a532e9b9</subsheetid><narrative>Terminates the Application.</narrative><display x="210" y="-105" w="180" h="60" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>418ab98c-e9b6-41fd-bb09-96738dc15d2d</onsuccess></stage><stage stageid="88072f1c-49d2-458f-bb81-5b282b750eb4" name="Note" type="Note"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><narrative>Get the path that is stored imn the queue and saves it in the varibles</narrative><display x="210" y="-105" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>c75fbde9-b098-454a-bb6b-d2358659e1ce</onsuccess></stage><stage stageid="ef99fe56-f781-4393-9a78-7d1d71137a15" name="Note" type="Note"><subsheetid>1d205568-8480-479a-940e-23f68579eaa7</subsheetid><narrative>Mark the item completed in the Calculate Client Security Hash Queue.</narrative><display x="180" y="135" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>72b56a2d-69fa-439c-b47d-6fb7eabeeba9</onsuccess></stage><stage stageid="aa6519da-84d6-487d-9e28-0ffe8f0d8592" name="Variable for SS Details." type="Block"><subsheetid>339d4ec6-0abe-4468-8a65-0c5099e142b9</subsheetid><loginhibit onsuccess="true" /><display x="-270" y="-30" w="180" h="105" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="f38fe1cf-7d68-47a0-97da-522191dbdccc" name="Launching the application" type="Block"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><loginhibit onsuccess="true" /><display x="-90" y="-75" w="210" h="150" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="236a3dfd-4362-47b3-bcc4-0bae8e481ab2" name="Note" type="Note"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><narrative>Launches or attaches the ACME system.</narrative><display x="240" y="-120" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>f0a2f002-5d65-47e8-b23e-72422020f3ee</onsuccess></stage><stage stageid="5c52e1a1-21d1-41af-a9ee-67ef49e95a15" name="Note" type="Note"><subsheetid>2a4db835-8273-4685-ad70-bca1f1494c47</subsheetid><narrative>Launches the same but if not launched as both the application runs on the same browser.</narrative><display x="-195" y="120" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>2bbb21c6-78e2-418d-88c6-b59ad13defd7</onsuccess></stage><stage stageid="f37709dd-92fe-413f-bd68-987af8cfe767" name="Note" type="Note"><narrative>Send the mail to the given mail address of excetion caught with the atteched SS if there.</narrative><display x="195" y="-15" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>50cf7344-b2b0-4b99-b7b1-50f8f4e12dc4</onsuccess></stage><stage stageid="ccac0c50-334c-46d8-ad38-cfb7544979ea" name="Exception Details" type="Block"><loginhibit onsuccess="true" /><display x="-240" y="-15" w="150" h="150" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="693aaf3b-2a7d-4682-a4a6-0cab7c04f467" name="Getting next Item and processing the queue." type="SubSheetInfo"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="-465" y="-60" w="180" h="120" /></stage><stage stageid="1bad29c5-b706-4ede-aa2e-3cdfc01bc36d" name="Start" type="Start"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="15" y="-105" /><onsuccess>0ac8a934-db37-4088-9f4c-48585ad93b8b</onsuccess></stage><stage stageid="0ac8a934-db37-4088-9f4c-48585ad93b8b" name="Get Next Item" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit /><narrative>This action gets the next item to be worked from the queue, returning its details and locking it so no other case can work it.

Items with higher priorities (lower numerical value) are processed first. Where the priority is the same, the next item is the one that has been in the queue the longest,  is not already locked, and is not already completed.

The Item ID returned is used to make further calls to update the work status for that item. It may be empty, in which case there are no items available. This can mean either a) the queue is empty, or b) the queue is not running. This mechanism can be used to cleanly stop all processes working a particular queue at the end of the next case. Items that have a 'deferred' time set will not be returned unless that time has been reached.</narrative><display x="15" y="-45" w="90" h="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /><inputs><input type="text" name="Queue Name" narrative="The name of the queue" expr="[Queue Name]" /><input type="text" name="Key Filter" narrative="Optionally, a key value to filter by. Only items with this key value will be considered." expr="" /><input type="text" name="Tag Filter" narrative="Optionally, a tag mask to filter by. This can consist of any number of tag searches - each term can be separated by a semi-colon and they are all applied to the search (ie. they are AND'ed terms not OR'ed terms). For example, &quot;Account: Joint; -Balance: Overdrawn; Card: *Visa*&quot; will include any items which match all the terms, ie. every item must have an 'Account: Joint' tag applied, no item can have a 'Balance: Overdrawn' tag applied, every item must have a tag applied which starts with 'Card: ' and then contains the text 'Visa'." expr="" /><input type="text" name="Sort Order" friendlyname="Sort Order" narrative="Sort order method (Priority, SLA, PriorityAndSLA)" expr="" /></inputs><outputs><output type="text" name="Item ID" narrative="The ID of the item retrieved - empty if there are none available." stage="Item ID" /><output type="collection" name="Data" narrative="The data associated with the item - a single collection row." stage="Work Item Data" /><output type="text" name="Status" narrative="The status of the item." stage="" /><output type="number" name="Attempts" narrative="The number of attempts already made to work this item." stage="" /></outputs><onsuccess>d1b8a010-8c51-4a4e-a086-00c96adcc3de</onsuccess><resource object="Blueprism.Automate.clsWorkQueuesActions" action="Get Next Item" /></stage><stage stageid="d1b8a010-8c51-4a4e-a086-00c96adcc3de" name="Got Item?" type="Decision"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="15" y="30" w="90" h="60" /><font family="Tahoma" size="10" style="Regular" color="000000" /><decision expression="[Item ID]&lt;&gt;&quot;&quot;" /><ontrue>3acc7569-7af2-48c8-becc-eb6a415bfa54</ontrue><onfalse>6d5d60fb-8852-4ee9-b068-c034860f7adc</onfalse></stage><stage stageid="3acc7569-7af2-48c8-becc-eb6a415bfa54" name="Note1" type="Note"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><narrative>An item is available, so proceed to work it as normal.</narrative><display x="15" y="135" w="120" h="90" /><font family="Tahoma" size="10" style="Bold" color="0000FF" /><onsuccess>18e795da-cae3-4f6e-8ed2-9fc5fd2a0f87</onsuccess></stage><stage stageid="6d5d60fb-8852-4ee9-b068-c034860f7adc" name="Note1" type="Note"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><narrative>No item is available</narrative><display x="150" y="30" w="120" h="90" /><font family="Tahoma" size="10" style="Bold" color="0000FF" /><onsuccess>a75f6ec1-76aa-43a4-81b3-cad733bb363f</onsuccess></stage><stage stageid="a75f6ec1-76aa-43a4-81b3-cad733bb363f" name="End1" type="End"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="270" y="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /></stage><stage stageid="ae5b4aec-9135-4356-ba29-cb6eb5f45059" name="anchor2" type="Anchor"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="-75" y="-45" w="10" h="10" /><font family="Tahoma" size="10" style="Regular" color="000000" /><onsuccess>0ac8a934-db37-4088-9f4c-48585ad93b8b</onsuccess></stage><stage stageid="e4d93648-5701-4c4a-870d-6a94ccc3e34e" name="Queue Name" type="Data"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit /><display x="-360" y="60" w="150" h="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /><datatype>text</datatype><initialvalue xml:space="preserve">Calculate Client Security Hash Queue</initialvalue><private /><alwaysinit /></stage><stage stageid="4990a4b8-d58e-4e22-ab08-c6e141092be6" name="Work Item Data" type="Collection"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="-360" y="255" w="150" h="60" /><datatype>collection</datatype><alwaysinit /></stage><stage stageid="7beb94b7-835e-4fea-8a80-42121255dfc2" name="Item ID" type="Data"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="-360" y="105" w="150" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="d8ac8f5c-5baf-47aa-a7cc-1e1f1f3d551d" name="Data For Hashing" type="Data"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="-360" y="150" w="150" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="44c8a905-3998-4775-9ca6-d9eb121907e9" name="Hashed Value" type="Data"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><display x="-360" y="195" w="150" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="4fe352ff-3360-4e7a-809a-64f58bd81864" name="Getting Details for Hashing" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><display x="150" y="255" w="90" h="30" /><outputs><output type="text" name="Data For Hashing" friendlyname="Data For Hashing" stage="Data For Hashing" /></outputs><onsuccess>5b066a70-5a85-4c23-bacf-129492328d86</onsuccess><resource object="Calculate Client Security Hash - ACME System Object" action="Getting Details for Hashing" /></stage><stage stageid="429c638a-48f5-4ef2-aea0-749ec2a3333f" name="Converting to Hash" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><display x="285" y="315" w="90" h="30" /><inputs><input type="text" name="Data For Hashing" friendlyname="Data For Hashing" expr="[Data For Hashing]" /></inputs><outputs><output type="text" name="Hashed Value" friendlyname="Hashed Value" stage="Hashed Value" /></outputs><onsuccess>b3136038-b873-4939-a84c-a7c1b50277d4</onsuccess><resource object="Calculate Client Security Hash - Sha-1 Object" action="Converting To Hash" /></stage><stage stageid="62584ce5-4990-4904-843b-d0523b92c463" name="Working On Item" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><display x="165" y="375" w="90" h="30" /><inputs><input type="text" name="Comment" friendlyname="Comment" expr="[Hashed Value]" /></inputs><onsuccess>c8571647-42f4-4b50-95ce-6fecc5ec30a0</onsuccess><resource object="Calculate Client Security Hash - ACME System Object" action="Working On Items" /></stage><stage stageid="18e795da-cae3-4f6e-8ed2-9fc5fd2a0f87" name="Search Work items on Acme" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><display x="15" y="255" w="90" h="30" /><inputs><input type="text" name="Work Item" friendlyname="Work Item" expr="[Work Item Data.Column2]" /></inputs><onsuccess>4fe352ff-3360-4e7a-809a-64f58bd81864</onsuccess><resource object="Calculate Client Security Hash - ACME System Object" action="Search Work items" /></stage><stage stageid="c8571647-42f4-4b50-95ce-6fecc5ec30a0" name="Close Update tab Of Acme" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><display x="45" y="375" w="90" h="30" /><onsuccess>8fef2f7c-12ea-44ee-9abb-5dc955e17adf</onsuccess><resource object="Calculate Client Security Hash - ACME System Object" action="Close Update tab" /></stage><stage stageid="8fef2f7c-12ea-44ee-9abb-5dc955e17adf" name="Mark Item Completed" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><narrative>Marks the item as completed, by updating the Completed timestamp and setting Locked to null. The item must be 'owned' by the calling process - i.e. it must have been retrieved using Get Next Item.</narrative><display x="-75" y="375" w="90" h="30" /><inputs><input type="text" name="Item ID" friendlyname="Item ID" narrative="The ID of the item to mark" expr="[Item ID]" /></inputs><onsuccess>ae5b4aec-9135-4356-ba29-cb6eb5f45059</onsuccess><resource object="Blueprism.Automate.clsWorkQueuesActions" action="Mark Completed" /></stage><stage stageid="5b066a70-5a85-4c23-bacf-129492328d86" name="Search Sha1 Tab" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><display x="285" y="255" w="90" h="30" /><onsuccess>429c638a-48f5-4ef2-aea0-749ec2a3333f</onsuccess><resource object="Calculate Client Security Hash - Sha-1 Object" action="Add Sha1 Tab" /></stage><stage stageid="b3136038-b873-4939-a84c-a7c1b50277d4" name="Search Work items on Acme" type="Action"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><loginhibit onsuccess="true" /><display x="285" y="375" w="90" h="30" /><inputs><input type="text" name="Work Item" friendlyname="Work Item" expr="[Work Item Data.Column2]" /></inputs><onsuccess>62584ce5-4990-4904-843b-d0523b92c463</onsuccess><resource object="Calculate Client Security Hash - ACME System Object" action="Search Work items" /></stage><stage stageid="d08f2265-1cfc-4543-8b21-7edc62508881" name="Note" type="Note"><subsheetid>a76acfbf-309f-4a1e-858a-6e5dd3cd42fc</subsheetid><narrative>Search Work item by using direct URL</narrative><display x="-180" y="195" w="150" h="60" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>18e795da-cae3-4f6e-8ed2-9fc5fd2a0f87</onsuccess></stage><stage stageid="a832d971-0298-4625-a737-1bc9cc49e68a" name="Note" type="Note"><subsheetid>a76acfbf-30