0" y="-45" w="150" h="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /><datatype>number</datatype><initialvalue>3</initialvalue><alwaysinit /></stage><stage stageid="697dfa2f-9aac-4cef-97ed-e07a311fda7e" name="GLOBAL Timeout - L" type="Data"><loginhibit /><display x="180" y="15" w="150" h="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /><datatype>number</datatype><initialvalue>10</initialvalue><alwaysinit /></stage><stage stageid="26a2704c-9ccb-4874-9179-fd313782eae1" name="GLOBAL Timeout - XL" type="Data"><loginhibit /><display x="180" y="45" w="150" h="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /><datatype>number</datatype><initialvalue>30</initialvalue><alwaysinit /></stage><stage stageid="631620b4-7b10-4186-9be1-916cbff44772" name="GLOBAL Timeout - XXL" type="Data"><loginhibit /><display x="180" y="75" w="150" h="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /><datatype>number</datatype><initialvalue>60</initialvalue><alwaysinit /></stage><stage stageid="a242a462-0c69-48db-9732-71e5f9e4727a" name="GLOBAL Timeout - XXS" type="Data"><loginhibit /><display x="180" y="-105" w="150" h="30" /><font family="Tahoma" size="10" style="Regular" color="000000" /><datatype>number</datatype><initialvalue>0.5</initialvalue><alwaysinit /></stage><stage stageid="e128756d-71bb-44d9-ae50-3918a248503e" name="Note1" type="Note"><subsheetid>04498905-1b38-46ea-bf89-108b53e17d1d</subsheetid><narrative>This just clicks the data items on the ACME System application.</narrative><display x="15" y="60" w="120" h="60" /><font family="Tahoma" size="10" style="Bold" color="0000FF" /><onsuccess>f37c4474-6fc0-413f-8c7f-b270a705bbea</onsuccess></stage><stage stageid="0cbc1cb7-a8d4-43e2-95c7-61fa7e1b135f" name="Varibles for reading all the data items" type="Block"><subsheetid>6b1f68ee-7ee7-4c03-99f9-f380923fe8bf</subsheetid><loginhibit /><display x="-360" y="-120" w="165" h="240" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="c4e5341f-b0da-454c-bc11-39b7b0e7a668" name="Credentials" type="Block"><subsheetid>353ef20f-90bb-4f16-a147-365dc7032e4c</subsheetid><loginhibit /><display x="-255" y="-30" w="135" h="135" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="6ace7831-df63-4515-b135-da4da10d3bf4" name="Note1" type="Note"><subsheetid>11757132-0db7-4d5c-b3cc-83a39ed65839</subsheetid><narrative>This gets the row count of the table of  data items on page of ACME System.</narrative><display x="15" y="30" w="120" h="60" /><font family="Tahoma" size="10" style="Bold" color="0000FF" /><onsuccess>ca015f4b-f8c8-4411-9ece-ad55b47f9b9f</onsuccess></stage><stage stageid="f58a88cb-f899-424c-8bb1-d3450b8ec523" name="Row Count" type="Block"><subsheetid>11757132-0db7-4d5c-b3cc-83a39ed65839</subsheetid><loginhibit /><display x="-225" y="-30" w="120" h="60" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="eb36c035-9483-436f-afb7-19454b6d0f94" name="Note1" type="Note"><subsheetid>a3497a2f-ca1a-4038-8a85-dd6baa91e1a9</subsheetid><narrative>It closes the additionnal window of the update tab.</narrative><display x="15" y="45" w="120" h="60" /><font family="Tahoma" size="10" style="Bold" color="0000FF" /><onsuccess>5e52acd4-2304-4d8d-a230-47fccccf25d3</onsuccess></stage><stage stageid="ebbec838-118d-4d99-b05d-78088d2bf50a" name="Hash value" type="Block"><subsheetid>42d1fde4-e8c7-4a6a-a678-520dac5c213a</subsheetid><loginhibit /><display x="-270" y="-15" w="150" h="75" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="154c67d1-9a3c-43e7-b642-1cb50d2656b9" name="Hashing Values" type="Block"><subsheetid>97b5b895-15ff-4ad5-9c12-d1a8441c0b50</subsheetid><loginhibit /><display x="-300" y="-75" w="150" h="120" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="7552269b-1a93-489e-998c-0c31afa56234" name="WIID" type="Block"><subsheetid>20b05fb7-5f9a-4b11-810d-595b2034bf0f</subsheetid><loginhibit /><display x="-225" y="-15" w="120" h="60" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="573c0927-94ce-487f-a771-7fedb22a89e0" name="Global variable to check attached" type="Block"><subsheetid>fdb63e8c-ac69-4a5a-90bd-3fd00109aa4a</subsheetid><loginhibit /><display x="-255" y="-15" w="165" h="60" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="e1e583a3-365c-4c6f-acc7-4ef343d86632" name="Global Timeouts" type="Block"><loginhibit /><display x="90" y="-135" w="165" h="240" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="573d9b17-2cf6-4f8d-8b4d-c6af2605edf2" name="Note2" type="Note"><subsheetid>6b1f68ee-7ee7-4c03-99f9-f380923fe8bf</subsheetid><narrative>This one reads the row count that needs to be work on, in table.</narrative><display x="165" y="-240" w="150" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>874f721e-0cbb-47a7-b4ee-8570910c7111</onsuccess></stage><stage stageid="3d8d329c-84d2-45f9-9852-4cd3c7a73467" name="Note2" type="Note"><subsheetid>6b1f68ee-7ee7-4c03-99f9-f380923fe8bf</subsheetid><narrative>Checks if the data item is WI5 or not and if it loads it on to the queue else skip it.</narrative><display x="-210" y="180" w="150" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>6b828af1-5761-4d6e-adde-0c41b5e5337b</onsuccess></stage><stage stageid="003b85a2-6ea6-4ad1-912c-a50b6dc6e017" name="Note2" type="Note"><subsheetid>6b1f68ee-7ee7-4c03-99f9-f380923fe8bf</subsheetid><narrative>Increments the page count and re-initialize te row count.</narrative><display x="435" y="-240" w="150" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>90df56b1-7dd4-4273-88ef-b8e107f0a126</onsuccess></stage><stage stageid="620edfb3-5f3e-4c6