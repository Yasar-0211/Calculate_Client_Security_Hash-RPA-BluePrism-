ve="Exeption Stage" expr="[Exception Stage]" /></inputs><onsuccess>236e64c1-cef2-4e71-8be9-45cbcaa82aad</onsuccess><processid>a866356a-ae72-4f8e-bd92-8643a99eb062</processid></stage><stage stageid="d881fa41-bd1d-411d-b0df-61795923de26" name="Sending Mail" type="Process"><subsheetid>6b6bdf6b-534d-464c-a431-26248dc9af37</subsheetid><loginhibit onsuccess="true" /><display x="-120" y="-15" w="90" h="30" /><inputs><input type="text" name="Messsage" friendlyname="Messsage" narrative="Emailing" expr="[Exception Detail]" /><input type="text" name="Attachment" friendlyname="Attachment" narrative="Email Attachment" expr="" /><input type="text" name="Subject" friendlyname="Subject" narrative="Exeption Stage" expr="[Exception Stage]" /></inputs><onsuccess>236e64c1-cef2-4e71-8be9-45cbcaa82aad</onsuccess><processid>a866356a-ae72-4f8e-bd92-8643a99eb062</processid></stage><stage stageid="d5128d47-b9ac-4221-aa69-1fc930f114c3" name="Note" type="Note"><subsheetid>6b6bdf6b-534d-464c-a431-26248dc9af37</subsheetid><narrative>Send the mail to the given mail address of excetion caught with the attached SS.</narrative><display x="195" y="165" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>45dc5c1d-0258-463f-9bd4-d9fb1458d278</onsuccess></stage><stage stageid="af577f9b-e728-48ff-8c6d-d438cf227dda" name="Note" type="Note"><subsheetid>6b6bdf6b-534d-464c-a431-26248dc9af37</subsheetid><narrative>Send the mail to the given mail address of exception caught without SS.</narrative><display x="-225" y="-135" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>d881fa41-bd1d-411d-b0df-61795923de26</onsuccess></stage><stage stageid="be512c9e-6721-4e78-bddb-fabe74c6019f" name="Sending Mail" type="SubSheet"><loginhibit onsuccess="true" /><display x="225" y="120" w="90" h="60" /><onsuccess>aa06a4ee-bae4-4803-8060-56afe7a59f78</onsuccess><processid>6b6bdf6b-534d-464c-a431-26248dc9af37</processid></stage></process></process>
        <process id="a866356a-ae72-4f8e-bd92-8643a99eb062" name="ID - XYZ - Calculate Client Security Hash - Reporter - p3" xmlns="http://www.blueprism.co.uk/product/process"><process name="ID - XYZ - Calculate Client Security Hash - Reporter - p3" version="1.0" bpversion="7.4.0.14902" narrative="" byrefcollection="true" processrunningmessage="" disableversioning="false"><view><camerax>0</camerax><cameray>0</cameray><zoom version="2">1.5625</zoom></view><preconditions /><endpoint narrative="" /><stage stageid="c9038839-b3d3-4578-b812-f4333de04542" name="Start" type="Start"><display x="15" y="-105" /><inputs><input type="text" name="Messsage" narrative="Emailing" stage="Messsage" /><input type="text" name="Attachment" narrative="Email Attachment" stage="Attachment" /><input type="text" name="Subject" narrative="Exeption Stage" stage="Subject" /></inputs><onsuccess>3fbe3e8b-90f7-4ede-937a-e44668a00bbc</onsuccess></stage><stage stageid="730393aa-6f70-423b-8583-4e8ac3e9ff52" name="End" type="End"><display x="15" y="90" /></stage><stage stageid="1a4847e8-f261-4006-ae56-66106f271c22" name="Stage1" type="ProcessInfo"><display x="-315" y="-135" w="150" h="90" /></stage><stage stageid="3fbe3e8b-90f7-4ede-937a-e44668a00bbc" name="Send Email" type="Action"><loginhibit onsuccess="true" /><display x="15" y="-15" /><inputs><input type="text" name="To" friendlyname="To" narrative="Mandatory. Any alphanumeric value allowed. Single Recipient = &quot;Name1@emaill.com&quot;; Multi Recipient = &quot;Name1@emaill.com; Name2@email.com&quot;" expr="[EV_email id]" /><input type="text" name="CC" friendlyname="CC" narrative="Optional. Any alphanumeric value allowed. Single Recipient = &quot;Name1@emaill.com&quot;; Multi Recipient = &quot;Name1@emaill.com; Name2@email.com&quot;. Default blank" expr="" /><input type="text" name="BCC" friendlyname="BCC" narrative="Optional. Any alphanumeric value allowed. Single Recipient = &quot;Name1@emaill.com&quot;; Multi Recipient = &quot;Name1@emaill.com; Name2@email.com&quot;. Default blank" expr="" /><input type="text" name="Subject" friendlyname="Subject" narrative="Optional. Any alphanumeric value allowed." expr="[Subject]" /><input type="text" name="Message" friendlyname="Message" narrative="Optional, HTML or plain text" expr="[Messsage]" /><input type="text" name="Attachments" friendlyname="Attachments" narrative="Optional, Semicolon--separated file paths. Default blank." expr="[Attachment]" /><input type="flag" name="IsHTML" friendlyname="IsHTML" narrative="Optional. True or False, default to True" expr="" /><input type="number" name="Sensitivity" friendlyname="Sensitivity" narrative="Optional. An integer between 0 and 3, default to 0." expr="" /><input type="number" name="Importance" friendlyname="Importance" narrative="Optional. An integer between 0 and 2 default to 1." expr="" /><input type="text" name="Account Display Name" friendlyname="Account Display Name" narrative="Optional. DisplayName of the email account. Default account is used if omitted." expr="" /><input type="text" name="Shared Mailbox" friendlyname="Shared Mailbox" narrative="Optional. Share Mailbox name or email address. Attempt to call Shared Mailbox is only initiated when a value is supplied." expr="" /><input type="text" name="Voting Options" friendlyname="Voting Options" narrative="Optional: A semicolon-delimited list of values. Example: “Cheese; Mushroom; Sausage; Combo; Veg Combo;”. " expr="" /><input type="text" name="Vote Recipients" friendlyname="Vote Recipients" narrative="Optional: A semicolon-delimited list of email addresses that should receive the results of any votes." expr="" /><input type="text" name="MIP Label GUID" friendlyname="MIP Label GUID" narrative="Optional: The unique identifier associated with an MIP sensitivity label within your organization." expr="" /><input type="text" name="Tenant ID" friendlyname="Tenant ID" narrative="Optional: Required when sending mail with an MIP sensitivity label." expr="" /></inputs><onsuccess>730393aa-6f70-423b-8583-4e8ac3e9ff52</onsuccess><resource object="MS Outlook Email VBO" action="Send Email" /></stage><stage stageid="da94d265-18de-46c0-9eda-9133665da206" name="Attachment" type="Data"><loginhibit onsuccess="true" /><display x="-165" y="120" w="120" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="69f76ad7-7951-4e03-88ed-e3fdea1f171c" name="Messsage" type="Data"><display x="-165" y="75" w="120" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="cbb98507-150a-45ab-8569-13807ff5f591" name="Subject" type="Data"><loginhibit onsuccess="true" /><display x="-165" y="30" w="120" h="30" /><datatype>text</datatype><initialvalue /><private /><alwaysinit /></stage><stage stageid="e7a2dbe1-83df-48fa-93aa-b877a04f6959" name="EV_email id" type="Data"><loginhibit onsuccess="true" /><display x="-165" y="-15" w="120" h="30" /><datatype>text</datatype><initialvalue xml:space="preserve">yasarmirza022002@gmail.com</initialvalue><exposure>Environment</exposure><private /><alwaysinit /></stage><stage stageid="e0f431ff-e9a8-4ffd-9989-de100f5e4044" name="Retry" type="Recover"><loginhibit /><display x="165" y="-105" w="90" h="30" /><onsuccess>d5e458bf-1748-4f94-9648-7d3ef72b97c3</onsuccess><attempts>2</attempts><bubbleException>False</bubbleException></stage><stage stageid="d5e458bf-1748-4f94-9648-7d3ef72b97c3" name="Retrying" type="Resume"><loginhibit /><display x="165" y="-15" w="90" h="30" /><onsuccess>3fbe3e8b-90f7-4ede-937a-e44668a00bbc</onsuccess></stage><stage stageid="da687100-fbc6-485f-bf80-7579ed676df8" name="Mailing Details" type="Block"><loginhibit onsuccess="true" /><display x="-255" y="-45" w="180" h="195" /><font family="Segoe UI" size="10" style="Regular" color="7FB2E5" /></stage><stage stageid="0a6bc0e5-4969-48cc-99b5-a2ca64b9c5f4" name="Note2" type="Note"><narrative>Sends the mail to the given email address with details of exception.</narrative><display x="180" y="90" w="180" h="90" /><font family="Tahoma" size="12" style="Bold" color="FF00FF" /><onsuccess>3fbe3e8b-90f7-4ede-937a-e44668a00bbc</onsuccess></stage></process></process>
